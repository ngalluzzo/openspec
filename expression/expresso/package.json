{
	"name": "@gooi/expresso",
	"version": "1.0.0",
	"type": "module",
	"main": "./src/expresso.ts",
	"types": "./src/public.ts",
	"exports": {
		".": {
			"types": "./src/public.ts",
			"import": "./src/expresso.ts",
			"default": "./src/expresso.ts"
		},
		"./emitter/*": {
			"types": "./src/emitter/*.ts",
			"import": "./src/emitter/*.ts",
			"default": "./src/emitter/*.ts"
		},
		"./testing/*": {
			"types": "./src/testing/*.ts",
			"import": "./src/testing/*.ts",
			"default": "./src/testing/*.ts"
		},
		"./package.json": "./package.json"
	},
	"private": true,
	"scripts": {
		"typecheck": "tsc -b",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"format": "biome format . --write"
	},
	"dependencies": {
		"@gooi/expresso-core": "workspace:*",
		"@gooi/expresso-std": "workspace:*"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"devDependencies": {
		"@types/bun": "latest"
	}
}
