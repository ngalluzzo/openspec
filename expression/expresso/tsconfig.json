{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"composite": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"tsBuildInfoFile": ".tsbuildinfo",
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"sourceMap": true,
		"noEmitOnError": true
	},
	"include": ["src/expresso.ts", "src/public.ts", "src/runtime.ts", "src/standard.ts", "src/wire.ts"],
	"exclude": ["dist", "node_modules", "**/*.test.ts", "**/*.spec.ts"],
	"references": [
		{
			"path": "../expresso-core"
		},
		{
			"path": "../expresso-std"
		}
	]
}
