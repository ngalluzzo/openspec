{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"composite": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"tsBuildInfoFile": ".tsbuildinfo",
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"sourceMap": true,
		"noEmitOnError": true
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "node_modules", "**/*.test.ts", "**/*.spec.ts"]
}
