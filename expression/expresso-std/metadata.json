							"output": "array"
						},
						{
							"description": "Get type of null",
							"input": {},
							"rule": {
								"type": [null]
							},
							"output": "null"
						}
					],
					"complexity": "O(1)",
					"jsonlogicCompatible": false
				}
			}
		}
