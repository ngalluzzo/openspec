{
	"name": "@reforge/transform",
	"version": "0.1.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./runner": {
			"types": "./src/runner/index.ts",
			"default": "./dist/runner/index.js"
		}
	},
	"scripts": {
		"build": "bun build --outdir dist src/index.ts src/runner/index.ts",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --write",
		"format": "biome format .",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@reforge/core": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"typescript": "^5"
	}
}
