{
	"name": "@reforge/cli",
	"version": "0.1.0",
	"type": "module",
	"bin": {
		"reforge": "./src/bin.ts"
	},
	"scripts": {
		"build": "bun build --compile --outfile dist/reforge src/bin.ts",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --write",
		"format": "biome format .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@reforge/core": "*",
		"@reforge/transform": "*",
		"@reforge/adapters": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"typescript": "^5"
	}
}
