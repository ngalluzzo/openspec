{
	"name": "@openspec/workspace",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc -b"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./package.json": "./package.json"
	},
	"openspec": {
		"models": {
			"documents": [
				"spec/workspace.model.openspec.yml"
			]
		},
		"capabilities": {
			"documents": [
				"spec/workspace.capability.openspec.yml"
			]
		},
		"patterns": {
			"documents": [
				"spec/workspace.procedure.openspec.yml",
				"spec/workspace.sdk.openspec.yml",
				"spec/workspace.host.openspec.yml",
				"spec/workspace.host-sdk.openspec.yml",
				"spec/workspace.provider.openspec.yml",
				"spec/workspace.cli.openspec.yml"
			]
		}
	},
	"dependencies": {
		"@openspec/action-executor": "workspace:*",
		"@openspec/adapter-registry": "workspace:*",
		"@openspec/action-executor-capability": "workspace:*",
		"@openspec/flow-executor": "workspace:*",
		"@openspec/flow-executor-capability": "workspace:*",
		"@gooi/expresso": "workspace:*",
		"@openspec/compiler": "workspace:*",
		"@openspec/materializer": "workspace:*",
		"@openspec/package-discovery": "workspace:*",
		"@openspec/storage-writer-capability": "workspace:*",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	}
}
